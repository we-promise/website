<script>
(function () {
  var _timer = null;

  function resetState() {
    if (_timer) { clearTimeout(_timer); _timer = null; }
    var crab = document.getElementById('openclaw-crab');
    var word = document.getElementById('personal-word');
    if (crab) {
      crab.style.cssText = '';
      crab.className = '';
      var arm = document.getElementById('crab-right-arm');
      if (arm) arm.removeAttribute('transform');
    }
    if (word) word.className = '';
  }

  function startCrab() {
    resetState();
    var crab = document.getElementById('openclaw-crab');
    var word = document.getElementById('personal-word');
    if (!crab || !word) return;

    _timer = setTimeout(function () {
      _timer = null;
      var wr  = word.getBoundingClientRect();
      var cw  = crab.offsetWidth;
      var ch  = crab.offsetHeight;
      var topPos    = wr.top + window.scrollY + wr.height / 2 - ch * 0.34; // align nozzle (34% down SVG) with strikethrough line
      // Position so nozzle tip (at ~95% of div width) aligns with word's left edge
      var slideDest = Math.max(wr.left - cw * 0.95, 4);

      // Place crab off-screen left at the right vertical position
      crab.style.top  = topPos + 'px';
      crab.style.left = '-200px';

      // Two rAFs ensure the browser paints the starting position before we add transition
      requestAnimationFrame(function () {
        requestAnimationFrame(function () {

          // ── Phase 1: slide in ──────────────────────────────────
          crab.style.transition = 'left 1.3s cubic-bezier(0.22,1,0.36,1)';
          crab.style.left = slideDest + 'px';

          setTimeout(function () {
            crab.style.transition = '';

            // ── Phase 2: scratch ───────────────────────────────────
            crab.classList.add('is-scratching');

            // Apply strikethrough mid-scratch
            setTimeout(function () {
              word.classList.add('is-scratched');
            }, 300);

            // ── Phase 3: step back & observe ───────────────────────
            setTimeout(function () {
              crab.classList.remove('is-scratching');

              // Step back slightly
              var observeLeft = Math.max(slideDest - 48, 4);
              crab.style.transition = 'left 0.8s cubic-bezier(0.22,1,0.36,1)';
              crab.style.left = observeLeft + 'px';

              // Lean body back like a painter appraising their work
              setTimeout(function () {
                crab.style.transition = 'transform 0.65s ease-out';
                crab.style.transformOrigin = 'bottom center';
                crab.style.transform = 'rotate(-14deg)';

                // Raise the OpenClaw arm in a triumphant appraisal gesture
                setTimeout(function () {
                  var arm = document.getElementById('crab-right-arm');
                  if (!arm) return;
                  var t0 = performance.now();
                  var dur = 750;
                  var target = -62; // degrees – raises claw upward
                  var px = 87, py = 52; // shoulder pivot in SVG user-units

                  requestAnimationFrame(function tick(ts) {
                    var p = Math.min((ts - t0) / dur, 1);
                    var e = 1 - Math.pow(1 - p, 3); // ease-out cubic
                    arm.setAttribute('transform',
                      'rotate(' + (target * e).toFixed(2) + ' ' + px + ' ' + py + ')');
                    if (p < 1) requestAnimationFrame(tick);
                  });
                }, 250);

              }, 300);
            }, 730); // end scratch
          }, 1350); // end slide-in
        });
      });
    }, 1000); // initial delay
  }

  // Turbo-aware initialisation
  document.addEventListener('turbo:load', startCrab);
  document.addEventListener('turbo:before-cache', resetState);

  // Fallback for non-Turbo initial load
  if (document.readyState !== 'loading') {
    startCrab();
  } else {
    document.addEventListener('DOMContentLoaded', startCrab);
  }
}());
</script>
